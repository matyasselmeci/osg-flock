#!/usr/bin/env python3

import glob
import platform
import re
import subprocess


def get_os_info():
    info = {}
    try:
        with open("/etc/os-release") as f:
            for line in f:
                line = line.strip()
                if "=" in line:
                    key, _, value = line.partition("=")
                    info[key] = value.strip('"')
    except FileNotFoundError:
        pass
    return info


def parse_kernel_version(release):
    """Extract a version tuple from a kernel release string.

    RHEL-family kernels (e.g. 4.18.0-553.120.1.el8_10.x86_64) return a
    5-tuple (major, minor, patch, rhel_release, patch_level) so both the
    RHEL release number (553) and the per-release patch level (120) participate
    in comparisons — the upstream triple 4.18.0 never changes across errata.

    All other kernels return a 3-tuple (major, minor, patch).
    """
    rhel_match = re.match(r"(\d+)\.(\d+)\.(\d+)-(\d+)\.(\d+).*\.el\d", release)
    if rhel_match:
        return tuple(int(x) for x in rhel_match.groups())
    match = re.match(r"(\d+)\.(\d+)\.(\d+)", release)
    if match:
        return tuple(int(x) for x in match.groups())
    return None


def kernel_tuple_str(t):
    """Format a version tuple as a human-readable string (e.g. '4.18.0-553.120')."""
    if len(t) == 5:
        return f"{t[0]}.{t[1]}.{t[2]}-{t[3]}.{t[4]}"
    return ".".join(str(x) for x in t)


# Minimum kernel version where all the current issues are fixed, keyed by (distro_id, version_id).
# Kernels at or above this version do not need the runtime socket test.
# RHEL-family entries use a 5-tuple (major, minor, patch, rhel_release, patch_level).
KERNEL_PATCHED = {
    ("almalinux", "8"): (4, 18, 0, 553, 122),
    ("almalinux", "9"): (5, 14, 0, 611, 50),
    ("almalinux", "10"): (6, 12, 0, 124, 53),
    ("centos", "7"): (3, 10, 0),
    ("debian", "13"): (6, 12, 86),
    ("rhel", "8"): (4, 18, 0, 553, 124),
    ("rhel", "9"): (5, 14, 0, 611, 55),
    ("rhel", "10"): (6, 12, 0, 124, 56),
    ("rocky", "8"): (4, 18, 0, 553, 124),
    ("rocky", "9"): (5, 14, 0, 611, 55),
    ("rocky", "10"): (6, 12, 0, 124, 56),
}


def check_module_disabled(module_name):
    """Return (not_loaded, blocked) for the given kernel module.

    not_loaded: True if lsmod shows the module is not currently active.
    blocked:    True if /etc/modprobe.d/ contains 'install <module> /bin/false'.
    """
    try:
        result = subprocess.run(["lsmod"], stdout=subprocess.PIPE, stderr=subprocess.PIPE, universal_newlines=True, check=True)
        not_loaded = not any(
            line.split()[0] == module_name
            for line in result.stdout.splitlines()
            if line.split()
        )
    except OSError:
        not_loaded = True

    blocked = False
    for path in glob.glob("/etc/modprobe.d/*"):
        try:
            with open(path) as f:
                for line in f:
                    tokens = line.split("#")[0].split()
                    if (
                        len(tokens) >= 3
                        and tokens[0] == "install"
                        and tokens[1] == module_name
                        and tokens[2] == "/bin/false"
                    ):
                        blocked = True
                        break
        except OSError:
            pass
        if blocked:
            break

    return not_loaded, blocked


def kernel_is_patched(distro_id, version_id, kernel_tuple):
    """Return True if patched, False if vulnerable, None if unknown distro/version."""
    key = (distro_id.lower(), version_id)
    if key not in KERNEL_PATCHED:
        return None
    fixed = KERNEL_PATCHED[key]
    if len(fixed) != len(kernel_tuple):
        return None
    return kernel_tuple >= fixed


def report_module(module, check_label):
    not_loaded, blocked = check_module_disabled(module)
    if not not_loaded:
        print(f"check-system-security: {check_label}: VULNERABLE: {module} module is loaded")
    elif not blocked:
        print(f"check-system-security: {check_label}: VULNERABLE: {module} module is not loaded but not blocked in modprobe.d")
    else:
        print(f"check-system-security: OK: {module} module is not loaded and is blocked in modprobe.d")


def copy_fail(distro_id):
    try:
        with open("/proc/cmdline") as f:
            cmdline = f.read()
    except OSError:
        cmdline = ""
    if "initcall_blacklist=algif_aead_init" in cmdline:
        print("check-system-security: OK: algif_aead_init is blacklisted in kernel cmdline")
        return
    if distro_id.lower() not in ("debian", "ubuntu"):
        print("check-system-security: copyfail: VULNERABLE: algif_aead_init not blacklisted in cmdline, on RHEL like system")
        return
    report_module("algif_aead", "copyfail")


def copy_fail2():
    report_module("xfrm_user", "copyfail2")


def dirty_frag():
    for module in ["esp4", "esp6", "rxrpc"]:
        report_module(module, "dirty_frag")


def main():
    os_info = get_os_info()
    distro_id = os_info.get("ID", "unknown")
    version_id = os_info.get("VERSION_ID", "unknown").split(".")[0]
    pretty_name = os_info.get("PRETTY_NAME", f"{distro_id} {version_id}")

    kernel_raw = platform.release()
    kernel_tuple = parse_kernel_version(kernel_raw)

    print(f"check-system-security: System:  {pretty_name}  ({distro_id} {version_id})")
    print(f"check-system-security: Kernel:  {kernel_raw}")

    patched = kernel_is_patched(distro_id, version_id, kernel_tuple) if kernel_tuple else None

    if patched is True:
        fixed_ver = KERNEL_PATCHED[(distro_id.lower(), version_id)]
        print(f"check-system-security: OK: kernel {kernel_raw} >= {kernel_tuple_str(fixed_ver)} (patched for {pretty_name})")
        return

    if patched is None:
        note = "no fixed-version data for this distribution - running runtime check"
    else:
        fixed_ver = KERNEL_PATCHED[(distro_id.lower(), version_id)]
        note = f"kernel {kernel_raw} < {kernel_tuple_str(fixed_ver)} - running runtime check"
    print(f"check-system-security: ({note})")

    copy_fail(distro_id)
    copy_fail2()
    dirty_frag()


if __name__ == "__main__":
    main()

